{
  "name": "synapseroute",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "services/frontend",
    "services/gateway",
    "services/order-service",
    "services/route-service",
    "services/driver-service",
    "services/analytics-service",
    "shared/proto"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "gateway:dev": "npm run dev --workspace=services/gateway",
    "db:generate": "npm run prisma:generate --workspace=services/gateway",
    "db:migrate": "npm run prisma:migrate --workspace=services/gateway",
    "db:seed": "npm run prisma:seed --workspace=services/gateway",
    "db:studio": "npm run prisma:studio --workspace=services/gateway",
    "proto:generate": "npm run generate --workspace=shared/proto",
    "proto:lint": "npm run lint --workspace=shared/proto",
    "docker:dev": "docker compose -f docker-compose.dev.yml up",
    "docker:dev:build": "docker compose -f docker-compose.dev.yml up --build",
    "docker:infra": "docker compose -f docker-compose.dev.yml up postgres redis -d",
    "docker:prod": "docker compose -f docker-compose.prod.yml up -d --build",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "docker:down": "docker compose -f docker-compose.dev.yml down"
  },
  "devDependencies": {
    "turbo": "^2.8.21"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@10.9.4"
}
