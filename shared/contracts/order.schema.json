{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synapseroute/contracts/order.schema.json",
  "title": "Order",
  "type": "object",
  "required": ["recipientName", "address", "locationType", "timePreference"],
  "properties": {
    "recipientName": { "type": "string", "minLength": 2 },
    "address": { "type": "string", "minLength": 5 },
    "locationType": { "type": "string", "enum": ["home", "apartment", "office"] },
    "timePreference": { "type": "string", "minLength": 2 }
  },
  "additionalProperties": false
}
