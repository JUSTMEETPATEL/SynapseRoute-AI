# ====================
# PRODUCTION ENVIRONMENT VARIABLES
# ====================
# IMPORTANT: DO NOT commit this file with real values!
# Copy this to .env.production and fill in real values.

# ====================
# DATABASE
# ====================
POSTGRES_USER=synapseroute
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=synapseroute_prod
POSTGRES_PORT=5432

# ====================
# REDIS
# ====================
REDIS_PORT=6379

# ====================
# FRONTEND (Next.js)
# ====================
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=https://api.your-domain.com
NEXT_PUBLIC_WS_URL=wss://api.your-domain.com
NEXT_PUBLIC_MAP_PROVIDER=leaflet

# ====================
# BACKEND (Phoenix)
# ====================
BACKEND_PORT=4000
SECRET_KEY_BASE=CHANGE_ME_GENERATE_WITH_mix_phx_gen_secret_min_64_chars
POOL_SIZE=10

# ====================
# ML SERVICES
# ====================
ML_SERVICE_PORT=8001
ML_WORKERS=4
ROUTING_ML_SERVICE_PORT=8002
ROUTING_ML_WORKERS=4

# ====================
# OBSERVABILITY
# ====================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_STRONG_PASSWORD
GF_SERVER_ROOT_URL=https://grafana.your-domain.com

# ====================
# NGINX (if used)
# ====================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
